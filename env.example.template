# ─── Azure OpenAI (Chat Model) ───────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-chat-2
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ─── Azure OpenAI (Embedding Model) ──────────────────────────────
AZURE_EMBEDDING_MODEL=text-embedding-3-large
AZURE_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name
AZURE_EMBEDDING_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_EMBEDDING_KEY=your-azure-embedding-key-here

# ─── Dhan (Free Trading API — Preferred) ──────────────────────
# Generate at: https://web.dhan.co/ -> Profile -> DhanHQ
DHAN_CLIENT_ID=your-dhan-client-id
DHAN_ACCESS_TOKEN=your-access-token

# ─── Shoonya (Free Broker — Finvasia) ──────────────────────────
# 0 Brokerage and 0 API Cost. Get at: https://shoonya.com
SHOONYA_USER_ID=
SHOONYA_PASSWORD=
SHOONYA_VENDOR_CODE=
SHOONYA_API_KEY=
SHOONYA_IMEI=

# ─── Zerodha Kite Connect (Paid API — Optional) ─────────────────
ZERODHA_API_KEY=
ZERODHA_ACCESS_TOKEN=
ZERODHA_API_SECRET=

# ─── Free Search & News (No Keys Needed) ────────────────────────
# The system now uses DuckDuckGo for free research.
# If you want to use paid options, fill these:
NEWS_API_KEY=
TAVILY_API_KEY=

# ─── Infrastructure ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./memory/chroma_db

# ─── Indian Market Risk Configuration ────────────────────────────
MAX_POSITION_SIZE_PCT=5.0
MAX_DAILY_DRAWDOWN_PCT=2.0
MAX_VOLATILITY_INDIAVIX=20

# ─── Indian Market Settings ───────────────────────────────────────
PORTFOLIO_VALUE_INR=1000000
DEFAULT_EXCHANGE=NSE
DEFAULT_CURRENCY=INR
